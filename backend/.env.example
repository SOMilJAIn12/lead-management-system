# ----------------------------------------------------------------------------
# Copy this file to ".env" in the backend/ folder and fill in real values.
# Never commit your real .env file.
# ----------------------------------------------------------------------------

# MongoDB connection
MONGO_URI=mongodb://localhost:27017
DB_NAME=lead_management

# Gmail SMTP credentials
# IMPORTANT: GMAIL_APP_PASSWORD must be a 16-character Gmail "App Password",
# NOT your normal Gmail password. Generate one at:
# https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the Google account)
GMAIL_USER=k
GMAIL_APP_PASSWORD=n
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Base URL of THIS backend - used to build the tracking pixel / click link
# that get embedded inside outgoing emails. Keep this as localhost:8000 for
# local development.
BASE_URL=http://localhost:8000

# URL of the frontend dev server - used for CORS.
FRONTEND_URL=https://lead-management-system-21vjou4sa-wkhewk.vercel.app
